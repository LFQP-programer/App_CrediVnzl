<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:App_CrediVnzl.ViewModels"
             xmlns:helpers="clr-namespace:App_CrediVnzl.Helpers"
             x:Class="App_CrediVnzl.Pages.ClientesPage"
             Title="Clientes"
             Shell.NavBarIsVisible="True"
             Shell.BackgroundColor="{StaticResource Tertiary}"
             Shell.ForegroundColor="{StaticResource White}"
             Shell.TitleColor="{StaticResource White}"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto,*" Padding="0" RowSpacing="0">

        <!-- Buscador -->
        <Frame Grid.Row="0" 
               BackgroundColor="White"
               CornerRadius="25"
               Padding="15,10"
               Margin="15,15,15,10"
               HasShadow="True">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                <Image Grid.Column="0"
                       Source="{x:Static helpers:IconPaths.Search}"
                       WidthRequest="20"
                       HeightRequest="20"
                       VerticalOptions="Center" />
                <Entry Grid.Column="1"
                       Placeholder="Buscar por nombre, telefono o cedula..."
                       Text="{Binding SearchText}"
                       BackgroundColor="Transparent" />
                <!-- Botón Agregar -->
                <Button Grid.Column="2"
                        BackgroundColor="{StaticResource Tertiary}"
                        TextColor="White"
                        FontSize="24"
                        FontAttributes="Bold"
                        WidthRequest="45"
                        HeightRequest="45"
                        CornerRadius="22"
                        Padding="0"
                        VerticalOptions="Center"
                        Command="{Binding AddClienteCommand}"
                        ImageSource="{x:Static helpers:IconPaths.Add}" />
            </Grid>
        </Frame>

        <!-- Lista de Clientes -->
        <Grid Grid.Row="1" RowDefinitions="*" Padding="0" RowSpacing="0">
            <RefreshView IsRefreshing="{Binding IsRefreshing}"
                         Command="{Binding RefreshCommand}">
                <CollectionView ItemsSource="{Binding Clientes}"
                               Margin="15,0">
                    <CollectionView.EmptyView>
                        <ContentView>
                            <VerticalStackLayout Padding="20"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center">
                                <Image Source="{x:Static helpers:IconPaths.Users}"
                                       WidthRequest="60"
                                       HeightRequest="60"
                                       HorizontalOptions="Center" />
                                <Label Text="No hay clientes registrados"
                                       FontSize="18"
                                       HorizontalOptions="Center"
                                       TextColor="{StaticResource Gray600}"
                                       Margin="0,10,0,0" />
                                <Label Text="Toca el boton + para agregar un cliente"
                                       FontSize="14"
                                       HorizontalOptions="Center"
                                       TextColor="{StaticResource Gray500}" />
                            </VerticalStackLayout>
                        </ContentView>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="White"
                                    Stroke="{Binding EstadoColor}"
                                    StrokeThickness="2"
                                    StrokeShape="RoundRectangle 15"
                                    Padding="20"
                                    Margin="0,0,0,15">
                                <Border.Shadow>
                                    <Shadow Brush="Black"
                                            Offset="0,4"
                                            Radius="8"
                                            Opacity="0.15" />
                                </Border.Shadow>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ClientesViewModel}}, Path=EditClienteCommand}"
                                                         CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                
                                <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="12">
                                    <!-- Fila 1: Avatar + Nombre + Badge -->
                                    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15">
                                        <!-- Avatar con Iniciales -->
                                        <Border Grid.Column="0"
                                                StrokeShape="RoundRectangle 24"
                                                BackgroundColor="{Binding ColorAvatar}"
                                                WidthRequest="48"
                                                HeightRequest="48"
                                                StrokeThickness="0"
                                                VerticalOptions="Center">
                                            <Label Text="{Binding Iniciales}"
                                                   FontSize="20"
                                                   FontAttributes="Bold"
                                                   TextColor="White"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center" />
                                        </Border>
                                        
                                        <!-- Nombre -->
                                        <Label Grid.Column="1"
                                               Text="{Binding NombreCompleto}"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               TextColor="#212121"
                                               VerticalOptions="Center" />
                                        
                                        <!-- Badge de Estado -->
                                        <Border Grid.Column="2"
                                                Stroke="{Binding EstadoColor}"
                                                StrokeThickness="2"
                                                BackgroundColor="{Binding EstadoColorClaro}"
                                                Padding="8,4"
                                                StrokeShape="RoundRectangle 10"
                                                VerticalOptions="Center">
                                            <Label Text="{Binding EstadoTexto}"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   TextColor="{Binding EstadoColor}" />
                                        </Border>
                                    </Grid>

                                    <!-- Fila 2: Contacto -->
                                    <Grid Grid.Row="1" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                        <HorizontalStackLayout Grid.Column="0" Spacing="8">
                                            <Image Source="{x:Static helpers:IconPaths.Phone}"
                                                   WidthRequest="20"
                                                   HeightRequest="20"
                                                   VerticalOptions="Center" />
                                            <Label Text="{Binding Telefono}"
                                                   FontSize="14"
                                                   TextColor="#616161"
                                                   VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                        
                                        <HorizontalStackLayout Grid.Column="1" Spacing="8" HorizontalOptions="End">
                                            <Image Source="{x:Static helpers:IconPaths.ID}"
                                                   WidthRequest="20"
                                                   HeightRequest="20"
                                                   VerticalOptions="Center" />
                                            <Label Text="{Binding Cedula, StringFormat='DNI: {0}'}"
                                                   FontSize="14"
                                                   TextColor="#616161"
                                                   VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </Grid>

                                    <!-- Fila 3: Separador -->
                                    <BoxView Grid.Row="2"
                                            HeightRequest="1"
                                            Color="#E0E0E0"
                                            IsVisible="{Binding PrestamosActivos, Converter={StaticResource IsGreaterThanZeroConverter}}" />

                                    <!-- Fila 4: Métricas en Mini-Cards -->
                                    <Grid Grid.Row="3" 
                                          ColumnDefinitions="*,*" 
                                          ColumnSpacing="12"
                                          IsVisible="{Binding PrestamosActivos, Converter={StaticResource IsGreaterThanZeroConverter}}">
                                        <!-- Mini-Card: Préstamos -->
                                        <Border Grid.Column="0"
                                                BackgroundColor="#F5F5F5"
                                                StrokeShape="RoundRectangle 12"
                                                Padding="15,12"
                                                StrokeThickness="0">
                                            <VerticalStackLayout Spacing="4">
                                                <Label Text="Préstamos"
                                                       FontSize="12"
                                                       TextColor="#757575" />
                                                <HorizontalStackLayout Spacing="6">
                                                    <Label Text="{Binding PrestamosActivos}"
                                                           FontSize="24"
                                                           FontAttributes="Bold"
                                                           TextColor="#2196F3"
                                                           VerticalOptions="Center" />
                                                    <Label Text="activos"
                                                           FontSize="12"
                                                           TextColor="#757575"
                                                           VerticalOptions="End"
                                                           Margin="0,0,0,4" />
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>
                                        </Border>
                                        
                                        <!-- Mini-Card: Deuda -->
                                        <Border Grid.Column="1"
                                                BackgroundColor="#F5F5F5"
                                                StrokeShape="RoundRectangle 12"
                                                Padding="15,12"
                                                StrokeThickness="0">
                                            <VerticalStackLayout Spacing="4">
                                                <Label Text="Deuda Total"
                                                       FontSize="12"
                                                       TextColor="#757575" />
                                                <Label Text="{Binding DeudaPendiente, StringFormat='${0:N0}'}"
                                                       FontSize="20"
                                                       FontAttributes="Bold"
                                                       TextColor="#F44336" />
                                            </VerticalStackLayout>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>
        </Grid>
    </Grid>
</ContentPage>
