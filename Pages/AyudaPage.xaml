<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:App_CrediVnzl.Helpers"
             x:Class="App_CrediVnzl.Pages.AyudaPage"
             Title="Centro de Ayuda"
             BackgroundColor="{StaticResource Gray100}">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">
            
            <!-- Cabecera / Info de la App -->
            <Frame BackgroundColor="{StaticResource Primary}" 
                   HasShadow="True" 
                   CornerRadius="15" 
                   Padding="20">
                <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Label Text="🚀" FontSize="48" HorizontalOptions="Center" />
                    <Label Text="CrediVnzl (Prestafácil)" 
                           TextColor="White" 
                           FontSize="24" 
                           FontAttributes="Bold" 
                           HorizontalOptions="Center" />
                    <Label Text="Versión 1.0.0" 
                           TextColor="{StaticResource Gray200}" 
                           FontSize="14" 
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Frame>

            <!-- Sección: Guías Rápidas -->
            <Label Text="Guías Rápidas" 
                   FontSize="18" 
                   FontAttributes="Bold" 
                   TextColor="{StaticResource Gray900}" 
                   Margin="0,10,0,0"/>

            <Frame BackgroundColor="White" HasShadow="False" CornerRadius="10" Padding="15">
                <VerticalStackLayout Spacing="15">

                    <VerticalStackLayout Spacing="5">
                        <Label Text="1. ¿Cómo registrar un préstamo?" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                        <Label Text="Ve a 'Nuevo Préstamo', selecciona el cliente, ingresa el monto, la tasa de interés y los plazos de pago. El sistema calculará automáticamente los intereses de acuerdo con la frecuencia." TextColor="{StaticResource Gray600}" FontSize="14" />
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="{StaticResource Gray200}" />

                    <VerticalStackLayout Spacing="5">
                        <Label Text="2. ¿Cómo funciona el registro de pagos?" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                        <Label Text="En la página de detalle del préstamo, al registrar un pago, puedes elegir qué monto destinas a abono de capital y cuánto a interés. El interés y el saldo total adeudado se descontarán conforme al pago que registres." TextColor="{StaticResource Gray600}" FontSize="14" />
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="{StaticResource Gray200}" />

                    <VerticalStackLayout Spacing="5">
                        <Label Text="3. ¿Los clientes tienen acceso a su cuenta?" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                        <Label Text="Sí, si les otorgas credenciales desde 'Configuración -> Gestionar Accesos'. Ellos podrán ingresar para ver su estado de cuenta de modo solo lectura." TextColor="{StaticResource Gray600}" FontSize="14" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <!-- Sección: Preguntas Frecuentes (FAQ) -->
            <Label Text="Preguntas Frecuentes (FAQ)" 
                   FontSize="18" 
                   FontAttributes="Bold" 
                   TextColor="{StaticResource Gray900}" 
                   Margin="0,10,0,0"/>

            <Frame BackgroundColor="White" HasShadow="False" CornerRadius="10" Padding="15">
                <VerticalStackLayout Spacing="15">

                    <VerticalStackLayout Spacing="5">
                        <Label Text="• ¿Dónde se guarda mi información?" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                        <Label Text="Los datos se almacenan de manera local en tu dispositivo para mayor privacidad. Si desinstalas la aplicación perderás tus clientes e historial de pagos si no tienes copia de seguridad." TextColor="{StaticResource Gray600}" FontSize="14" />
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="{StaticResource Gray200}" />

                    <VerticalStackLayout Spacing="5">
                        <Label Text="• ¿Qué sucede si elimino a un cliente?" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                        <Label Text="Cuidado: Eliminar un cliente también borrará todos sus préstamos y el historial de pagos asociados. Esta acción no se puede deshacer." TextColor="{StaticResource Gray600}" FontSize="14" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <!-- Soporte Técnico -->
            <Label Text="Soporte y Contacto" 
                   FontSize="18" 
                   FontAttributes="Bold" 
                   TextColor="{StaticResource Gray900}" 
                   Margin="0,10,0,0"/>

            <Button Text="💬 Contactar Soporte (WhatsApp)" 
                    BackgroundColor="#25D366" 
                    TextColor="White" 
                    FontAttributes="Bold" 
                    CornerRadius="8" 
                    HeightRequest="50" 
                    Clicked="OnContactarSoporteClicked" />

            <Label Text="Términos de uso y Política de privacidad." 
                   TextColor="{StaticResource Gray500}" 
                   FontSize="12" 
                   HorizontalOptions="Center" 
                   Margin="0,20,0,20"/>
                   
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>